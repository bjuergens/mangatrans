{
  "name": "mangatrans",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "PWA for learning Japanese by translating manga",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "setup": "npm ci --no-audit --no-fund && npx playwright install --with-deps chromium",
    "check:typecheck": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "check:test": "vitest run",
    "check:build": "tsc --noEmit && vite build",
    "check:test:e2e": "playwright test",
    "check:all": "npm run check:typecheck && npm run check:lint && npm run check:format && npm run check:test && npm run check:build && npm run check:test:e2e",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fake-indexeddb": "^6.0.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.7"
  }
}
